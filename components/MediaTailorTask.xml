<component name="MediaTailorTask" extends="Task">
    <interface>
        <!-- Required: Video node to play the stitched stream -->
        <field id="videoNode"    type="node"/>
        <!-- Required: New Relic Agent node -->
        <field id="nr"           type="node"/>
        <!-- Required: MediaTailorTracker node. Must be created in the scene
             thread so RAFX's listener dispatch can reach it. -->
        <field id="tracker"      type="node"/>
        <!-- Required: MediaTailor session-init or HLS manifest URL -->
        <field id="streamUrl"    type="string" value=""/>
        <!-- Optional: "VOD" (default) or "LIVE" -->
        <field id="streamType"   type="string" value="VOD"/>
        <!-- Optional: "hls" (default) or "dash" -->
        <field id="streamFormat" type="string" value="hls"/>
    </interface>

    <script type="text/brightscript" uri="pkg:/source/rafxssai.brs"/>
    <script type="text/brightscript" uri="pkg:/source/MediaTailorTrackerInterface.brs"/>
    <script type="text/brightscript" uri="pkg:/components/MediaTailorTask.brs"/>
</component>
